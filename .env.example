# AI provider selection: anthropic | openai | ollama | openrouter
AI_PROVIDER=anthropic

# Anthropic Claude Haiku
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Ollama
OLLAMA_MODEL=llama3
# Optional custom URL for Ollama API
# OLLAMA_URL=http://localhost:11434

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# App behavior
POLL_INTERVAL_SECONDS=30
MAX_LOG_LINES=200
PORT=8080

# Optional explicit database path
DB_PATH=data/docwatch.db

# Optional SQLite lock handling tuning
DB_TIMEOUT_SECONDS=10
DB_LOCK_RETRY_COUNT=3
DB_LOCK_RETRY_DELAY_SECONDS=0.15
